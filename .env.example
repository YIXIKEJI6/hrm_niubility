# Enterprise WeChat (企业微信)
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
WECOM_SECRET=your_agent_secret
WECOM_CONTACT_SECRET=your_contact_secret
WECOM_CALLBACK_TOKEN=your_callback_token
WECOM_CALLBACK_AES_KEY=your_callback_aes_key

# WeChat Work Smart Spreadsheet (薪资表)
WECOM_SALARY_DOC_ID=your_salary_doc_id
WECOM_SALARY_SHEET_ID=your_salary_sheet_id

# JWT (use a cryptographically random 256-bit string)
JWT_SECRET=generate_a_strong_random_secret_here

# DeepSeek AI
DEEPSEEK_API_KEY=your_deepseek_api_key

# Gemini AI (optional)
GEMINI_API_KEY=your_gemini_api_key

# Database
DB_TYPE=sqlite

# Server
SERVER_PORT=3001
APP_URL=http://localhost:5173
NODE_ENV=development
